# Environment Configuration

# Database
DATABASE_URL=sqlite:///./database/synthetic_gan.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Streamlit Configuration
STREAMLIT_PORT=8501

# Model Configuration
DEFAULT_MODEL=dcgan
IMAGE_SIZE=128
BATCH_SIZE=32
EPOCHS=50
LEARNING_RATE=0.0002
NOISE_DIM=100

# Paths
DATASET_PATH=./Dataset
SYNTHETIC_DATA_PATH=./Synthetic Data
MODEL_CHECKPOINT_PATH=./models/checkpoints
LOGS_PATH=./logs

# Training Configuration
SAVE_INTERVAL=5
SAMPLE_INTERVAL=100
MAX_UPLOAD_SIZE=100

# Security
SECRET_KEY=your-secret-key-here
ALLOWED_EXTENSIONS=jpg,jpeg,png

# GPU Configuration
USE_GPU=True
GPU_MEMORY_LIMIT=4096
